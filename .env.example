# MongoDB connection string
# For local Docker development use:
MONGODB_URI=******localhost:27017/banking?authSource=admin

# JWT secret – use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Nodemailer SMTP settings
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_password
SMTP_FROM="Banking Platform <noreply@banking.local>"

# Base URL used for email links
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ------------------------------------------------------------------
# First-time seed: run `npm run seed` to create the initial admin.
# ------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin User
